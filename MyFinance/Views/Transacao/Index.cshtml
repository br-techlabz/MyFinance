
@{
    ViewData["Title"] = "Index";
}

<h3>Minhas transações</h3>


<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Data</th>
            <th>Tipo</th>
            <th>Valor</th>
            <th>Histórico</th>
            <th>Conta</th>
            <th>Plano de Contas</th>
            <th></th>
        </tr>
    </thead>

    @{
        foreach (var item in (List<TransacaoModel>)ViewBag.ListaTransacoes)
        {
            <tbody>
                <tr>
                    <td>@item.Id.ToString()</td>
                    <td>@item.Data.ToString()</td>
                    <td>@item.Tipo.ToString()</td>
                    <td>R$ @item.Valor.ToString()</td>
                    <td>@item.Descricao.ToString()</td>
                    <td>@item.NomeConta.ToString()</td>
                    <td>@item.PlanoConta.ToString()</td>


                    <td><button type="button" class="btn btn-danger" onclick="Excluir(@item.Id.ToString())">Excluir</button></td>
                    <td><button type="button" class="btn btn-success" onclick="Editar(@item.Id.ToString())">Editar</button></td>
                </tr>
            </tbody>
        }
    }

</table>

<button type="button" class="btn btn-block btn-primary" onclick="RegistrarTransacao()">Registrar Transação</button>

<script>
    function RegistrarTransacao()
    {
        window.location.href = "../Transacao/Registrar/";
    }

    function Excluir(id)
    {
        window.location.href = "../Transacao/Excluir/" + id;
    }

    function Editar(id) {
        window.location.href = "../Transacao/Registrar/" + id;
    }
</script>