
<h3>Você deseja Excluir a transacao selecionada?</h3>

<p>Id: @ViewBag.Registro.Id.ToString()</p>
<p>Data: @ViewBag.Registro.Data.ToString()</p>
<p>Histórico: @ViewBag.Registro.Descricao.ToString()</p>
<p>Valor: @ViewBag.Registro.Valor.ToString()</p>



<button type="button" onclick="Cancelar()" class="btn btn-block btn-default">Cancelar</button>
<button type="button" onclick="Excluir( @ViewBag.Registro.Id.ToString() )" class="btn btn-block btn-danger">Excluir</button>

<script>
    function Excluir(id) {
        window.location.href = "../../Transacao/Excluir/" + id;
    }

    function Cancelar() {
        window.location.href = "../../Transacao/Index";
    }


</script>

